# CSL-CtfShitCli — .env configuration
# Copy this file to .env and fill in your CTFd credentials.
# This file is used as a fallback when no .ctf_config.json workspace is found.
# NEVER commit your real .env file.

# ── Required ──────────────────────────────────────────────────────────────────

# CTFd Platform URL (http or https)
CTF_URL=https://ctf.example.com

# API Token from CTFd: Settings → API Token
CTF_TOKEN=ctfd_your_api_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Scoreboard polling interval in seconds (default: 30)
POLL_INTERVAL=30

# API request timeout in seconds (default: 15)
API_TIMEOUT=15

# Maximum retry attempts for failed requests (default: 3)
MAX_RETRIES=3

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# Logs are written to ctf_client.log (never to the terminal)
LOG_LEVEL=INFO

# Discord webhook URL for flag-solved notifications (optional)
DISCORD_WEBHOOK_URL=

# LLM API Key for autonomous code analysis (optional)
# Get your free key from Google AI Studio (Gemini)
LLM_API_KEY=
